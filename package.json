{
  "name": "gopal-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Enterprise Portfolio Website - Gopal Das | DevOps Consultant and Solution Architect",
  "author": "Gopal Das <gopal1409@gmail.com>",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write src/**/*.{js,jsx,css,json}",
    "test": "vitest",
    "docker:build": "docker build -t gopal-portfolio .",
    "docker:run": "docker run -p 80:80 gopal-portfolio",
    "docker:compose": "docker-compose up --build",
    "docker:compose:prod": "docker-compose -f docker-compose.prod.yml up --build -d"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^7.0.0",
    "@mui/material": "^6.0.0",
    "@mui/icons-material": "^6.0.0",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "framer-motion": "^12.0.0",
    "@emailjs/browser": "^4.0.0",
    "react-countup": "^6.5.0",
    "react-intersection-observer": "^9.13.0",
    "react-helmet-async": "^1.3.0",
    "@mui/lab": "^6.0.0-alpha"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "vite-plugin-svgr": "^4.3.0",
    "terser": "^5.19.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.3.0",
    "vitest": "^2.1.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}